# MongoDB Atlas
# 1. https://cloud.mongodb.com 에서 클러스터 생성
# 2. Database Access에서 사용자 생성
# 3. Network Access에서 IP 허용 (0.0.0.0/0)
# 4. Connect > Drivers에서 connection string 복사
# 5. <username>, <password>를 실제 값으로 교체
# 6. 마지막에 데이터베이스 이름(dbi-lab) 추가
# MongoDB-Compass                                                                             
MONGO_URI=mongodb://localhost:27017/dbi-lab  
# MongdoDB-Atlas
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/dbi-lab?retryWrites=true&w=majority

# Admin Key (10자 이상, 분기별 자동 갱신)
ADMIN_KEY=initialKey2026

# Session
SESSION_SECRET=your-session-secret-here

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Recipients
PROFESSOR_EMAIL=professor@hanyang.ac.kr
ADMIN_EMAIL=admin@hanyang.ac.kr

# Server
PORT=5001
NODE_ENV=development
